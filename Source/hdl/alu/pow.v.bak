module Pow(  input clk, input [7:0] in, output reg [7:0] out);
reg [7:0] temp = 1;
reg [7:0] temp2;
reg temp3;
wire [7:0] adderout;
wire carryout;

Adder8 adder(in,temp2,temp3,adderout,carryout);  


  always @(posedge clk) begin
    for( temp =1 ; temp == in; temp = temp+1)
    begin
    assign temp2 = adderout;
    assign temp3 = carryout;
    end
    out = adderout;
  end
endmodule

